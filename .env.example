# MeetingMind public example configuration. Copy to .env.local for local use.
HUGGING_FACE_HUB_TOKEN=
HUGGING_FACE_TOKEN=
MEETINGMIND_CONFIG=config/local.toml
MEETINGMIND_LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Optional: OpenRouter cloud provider for higher-quality synthesis.
# Local-first remains the default — set this only if you switch
# Settings → Provider to "OpenRouter". When selected, the cleaned
# transcript leaves your machine; audio never does. No subscription,
# no lock-in. Get a key at https://openrouter.ai/keys
OPENROUTER=
# Legacy alias — also accepted if you already have this name set.
# OPENROUTER_API_KEY=

# Add local ASR vocabulary terms in ignored config/local.vocabulary.txt or
# [asr].vocabulary_terms inside config/local.toml. Do not put private
# meeting/client names in tracked files.
